{
  "name": "@respectify/astro",
  "version": "0.1.0",
  "description": "Official Respectify integration for Astro sites.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://www.npmjs.com/package/@respectify/astro",
  "repository": {
    "type": "git",
    "url": "https://github.com/Respectify/respectify-astro-integration.git"
  },
  "bugs": {
    "url": "https://github.com/Respectify/respectify-astro-integration/issues"
  },
  "keywords": [
    "astro",
    "astro-integration",
    "respectify",
    "moderation"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
